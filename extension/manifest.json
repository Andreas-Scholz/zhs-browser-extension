{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "default_locale": "de",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "homepage_url": "https://github.com/Andreas-Scholz/zhs-browser-extension",
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zhs-browser-extension@andreasscholz.com",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "113.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://kurse.zhs-muenchen.de/*/product-offers/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://kurse.zhs-muenchen.de/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["_locales/*/messages.json"],
      "matches": ["*://kurse.zhs-muenchen.de/*"]
    }
  ]
}
